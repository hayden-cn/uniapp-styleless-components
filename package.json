{
  "name": "uniapp-styleless-components",
  "version": "1.0.0",
  "description": "A styleless component library for uni-app, providing unstyled Vue 3 components with semantic classNames/styles props for full customization.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./components/*": "./src/components/*"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "uniapp",
    "styleless",
    "components",
    "vue3",
    "unstyled"
  ],
  "author": "hayden",
  "license": "MIT",
  "files": [
    "src",
    "tsconfig.json"
  ],
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.5.2",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@dcloudio/types": "^3.4.31",
    "@dcloudio/uni-app": "3.0.0-alpha-5010320260611001",
    "@types/lodash-es": "^4.17.12",
    "typescript": "^6.0.3",
    "typescript-builtins-extended": "^0.2.1",
    "vue": "^3.4.21"
  },
  "peerDependencies": {
    "@dcloudio/uni-app": ">=3.0.0",
    "vue": "^3.4.21"
  },
  "dependencies": {
    "lodash-es": "^4.18.1"
  }
}
